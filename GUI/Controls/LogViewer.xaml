<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#1E1E1E" CornerRadius="6" Padding="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="4,4,0,0" Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Log Output" FontSize="12"
                               FontFamily="Segoe UI" Foreground="#CCCCCC" VerticalAlignment="Center" />
                    <CheckBox x:Name="chkAutoScroll" Grid.Column="1" Content="Auto-scroll"
                              FontSize="11" FontFamily="Segoe UI" Foreground="#AAAAAA"
                              IsChecked="True" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <Button x:Name="btnClearLog" Grid.Column="2" Content="Clear"
                            FontSize="11" FontFamily="Segoe UI" Foreground="#AAAAAA"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Padding="8,2" />
                </Grid>
            </Border>

            <!-- Log content -->
            <TextBox x:Name="txtLogContent" Grid.Row="1"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas"
                     FontSize="12"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     BorderThickness="0"
                     Padding="12,8"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True" />
        </Grid>
    </Border>
</UserControl>
