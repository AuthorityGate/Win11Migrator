<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,8"
            BorderBrush="#D1D1D1" BorderThickness="1">
        <StackPanel>
            <!-- Phase header -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtPhase" Grid.Column="0" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="#1A1A1A" />
                <TextBlock x:Name="txtPercent" Grid.Column="1" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="#0078D4" />
            </Grid>

            <!-- Progress bar -->
            <Border Height="6" CornerRadius="3" Background="#E8E8E8" Margin="0,0,0,8">
                <Border x:Name="progressFill" Height="6" CornerRadius="3" Background="#0078D4"
                        HorizontalAlignment="Left" Width="0" />
            </Border>

            <!-- Status text -->
            <TextBlock x:Name="txtStatus" FontSize="12" FontFamily="Segoe UI" Foreground="#605E5C"
                       TextTrimming="CharacterEllipsis" />

            <!-- Item counter -->
            <TextBlock x:Name="txtCounter" FontSize="11" FontFamily="Segoe UI" Foreground="#A19F9D"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</UserControl>
