<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Import Source">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
                <ResourceDictionary Source="../Styles/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select Migration Package" Style="{StaticResource SubtitleText}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="Browse to the folder containing your migration package, or select a detected source."
                   Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

        <!-- Browse -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtPackagePath" Grid.Column="0" Style="{StaticResource SearchTextBox}"
                         IsReadOnly="True" Margin="0,0,12,0" />
                <Button x:Name="btnBrowsePackage" Grid.Column="1" Content="Browse..."
                        Style="{StaticResource PrimaryButton}" Padding="16,8" />
            </Grid>
        </Border>

        <!-- Detected sources -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Detected Migration Packages:" Style="{StaticResource HeadingText}" Margin="0,0,0,12" />
                <StackPanel x:Name="panelDetectedSources" />

                <!-- Package Info (shown after selection) -->
                <Border x:Name="panelPackageInfo" Style="{StaticResource CardPanel}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Package Details" Style="{StaticResource HeadingText}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Computer:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtSourceComputer" Grid.Row="0" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Export Date:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtExportDate" Grid.Row="1" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="OS Version:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtSourceOS" Grid.Row="2" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Applications:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtAppCount" Grid.Row="3" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="User Data Items:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtDataCount" Grid.Row="4" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="User:" Style="{StaticResource BodyText}" />
                            <TextBlock x:Name="txtSourceUser" Grid.Row="5" Grid.Column="1" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
