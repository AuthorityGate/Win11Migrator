<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Scanning">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,32">
        <StackPanel VerticalAlignment="Center" MaxWidth="600" HorizontalAlignment="Center">

            <TextBlock x:Name="txtTitle" Text="Ready to Scan" Style="{StaticResource TitleText}"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock x:Name="txtScanStatus" Text="Click the button below to scan your PC for apps, files, and settings."
                       Style="{StaticResource BodyText}" HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

            <!-- Start Scan Button -->
            <Button x:Name="btnStartScan" Content="Start Scan" HorizontalAlignment="Center"
                    Style="{StaticResource PrimaryButton}" Padding="32,12" FontSize="16" Margin="0,0,0,24" />

            <!-- Overall Progress -->
            <ProgressBar x:Name="progressOverall" Style="{StaticResource MigratorProgressBar}"
                         Value="0" Maximum="100" Height="8" Margin="0,0,0,8" Visibility="Collapsed" />
            <TextBlock x:Name="txtProgressPercent" Text="0%" Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Right" Margin="0,0,0,24" Visibility="Collapsed" />

            <!-- Phase indicators -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconApps" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="Installed Applications" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtAppsCount" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconUserData" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="User Data &amp; Files" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtUserDataSize" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconBrowsers" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="Browser Profiles" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtBrowserCount" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconSettings" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="System Settings" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtSettingsCount" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconAppProfiles" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="Application Profiles" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtAppProfileCount" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="iconInstallMethods" Grid.Column="0" Text="&#x25CB;" Margin="0,0,12,0" FontSize="14" />
                        <TextBlock Grid.Column="1" Text="Install Methods" Style="{StaticResource BodyText}" />
                        <TextBlock x:Name="txtInstallMethodCount" Grid.Column="2" Text="Waiting..." Style="{StaticResource CaptionText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Log area -->
            <TextBox x:Name="txtLog" Height="120" Margin="0,16,0,0" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                     Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}"
                     Padding="8" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
