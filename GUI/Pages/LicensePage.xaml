<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="License Agreement">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="License Agreement" Style="{StaticResource SubtitleText}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="Please read and accept the license agreement to continue."
                   Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" />

        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="16" Margin="0,0,0,16">
            <TextBox x:Name="txtLicense" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" BorderThickness="0"
                     FontFamily="Consolas" FontSize="12" Background="Transparent" />
        </Border>

        <CheckBox x:Name="chkAcceptLicense" Grid.Row="3"
                  Content="I have read and accept the license agreement"
                  Style="{StaticResource MigratorCheckBox}" FontSize="14" />
    </Grid>
</Page>
