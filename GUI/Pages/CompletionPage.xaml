<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Complete">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
                <ResourceDictionary Source="../Styles/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="650" HorizontalAlignment="Center">

                <!-- Success icon -->
                <Path x:Name="iconComplete"
                      Data="{StaticResource CheckIcon}" Fill="{StaticResource SuccessBrush}"
                      Width="64" Height="64" Stretch="Uniform"
                      HorizontalAlignment="Center" Margin="0,24,0,16" />

                <TextBlock x:Name="txtCompleteTitle" Text="Migration Complete!"
                           Style="{StaticResource TitleText}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock x:Name="txtCompleteSubtitle"
                           Text="Your data has been successfully packaged for transfer."
                           Style="{StaticResource BodyText}" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,32" />

                <!-- Summary Card -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Summary" Style="{StaticResource HeadingText}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock x:Name="txtAppsSummary" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="Apps" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="txtDataSummary" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="Data Folders" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock x:Name="txtBrowserSummary" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="Browsers" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock x:Name="txtSettingsSummary" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="Settings" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Package Location -->
                <Border x:Name="panelPackagePath" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Package Location" Style="{StaticResource HeadingText}" Margin="0,0,0,8" />
                        <TextBlock x:Name="txtPackageLocation" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource PrimaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Reports -->
                <Border x:Name="panelReports" Style="{StaticResource CardPanel}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Reports" Style="{StaticResource HeadingText}" Margin="0,0,0,12" />
                        <Button x:Name="btnCompletionReport" Content="Open Completion Report"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                Margin="0,0,0,8" />
                        <Button x:Name="btnManualReport" Content="Open Manual Install Guide"
                                Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"
                                Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Next Steps -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Next Steps" Style="{StaticResource HeadingText}" Margin="0,0,0,12" />
                        <StackPanel x:Name="panelExportSteps">
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                1. Transfer the migration package to your new PC
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                2. Run Win11Migrator on the new PC and select Import
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                3. Browse to the migration package and follow the wizard
                            </TextBlock>
                        </StackPanel>
                        <StackPanel x:Name="panelImportSteps" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                1. Review the completion report for any failed items
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                2. Check the manual install guide for apps that need manual setup
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,4">
                                3. Restart your computer to apply all changes
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Open Folder button -->
                <Button x:Name="btnOpenFolder" Content="Open Package Folder"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Margin="0,16,0,32" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
