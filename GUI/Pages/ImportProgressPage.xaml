<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Importing">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtImportTitle" Text="Restoring Your Data..."
                   Style="{StaticResource SubtitleText}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" x:Name="txtImportPhase" Text="Preparing..."
                   Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

        <!-- Overall progress -->
        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="progressImport" Grid.Column="0" Style="{StaticResource MigratorProgressBar}"
                         Value="0" Maximum="100" Margin="0,0,12,0" />
            <TextBlock x:Name="txtImportPercent" Grid.Column="1" Text="0%" Style="{StaticResource BodyText}" Width="45" />
        </Grid>

        <!-- Current item -->
        <TextBlock Grid.Row="3" x:Name="txtCurrentImportItem" Text=""
                   Style="{StaticResource CaptionText}" Margin="0,0,0,8" TextTrimming="CharacterEllipsis" />

        <!-- Stats -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="4" Padding="16,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtSuccessCount" Text="0" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Succeeded" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtFailedCount" Text="0" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource ErrorBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Failed" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="txtRemainingCount" Text="0" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Remaining" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log -->
        <Border Grid.Row="5" Style="{StaticResource CardPanel}" Padding="0" Margin="0">
            <TextBox x:Name="txtImportLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11" Background="Transparent" BorderThickness="0"
                     Padding="12" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Page>
