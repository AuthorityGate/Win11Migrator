<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Network Target">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles/Colors.xaml" />
                <ResourceDictionary Source="../Styles/Typography.xaml" />
                <ResourceDictionary Source="../Styles/Controls.xaml" />
                <ResourceDictionary Source="../Styles/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="#F5F0E6" Margin="48,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select Target Computer" Style="{StaticResource SubtitleText}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" Text="Choose the destination PC for direct network migration, or enter a hostname manually."
                   Style="{StaticResource BodyText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Network Discovery Section -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{StaticResource ComputerIcon}" Fill="{StaticResource PrimaryBrush}"
                                  Width="24" Height="24" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Network Discovery" Style="{StaticResource HeadingText}" />
                                <TextBlock x:Name="txtScanStatus" Text="Click Scan to discover computers on your network."
                                           Style="{StaticResource CaptionText}" />
                            </StackPanel>
                            <Button x:Name="btnScanNetwork" Grid.Column="2" Content="Scan Network"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6" FontSize="12"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <ListBox x:Name="lstComputers" MinHeight="80" MaxHeight="200"
                                 Background="{StaticResource SurfaceBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                 Padding="4" Margin="0,4,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ComputerName}" FontWeight="SemiBold"
                                                   FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding IPAddress}" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding OS}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Ellipse Grid.Column="3" Width="8" Height="8" Margin="8,0,0,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource TextDisabledBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Online}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Manual Entry Section -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Target Computer" Style="{StaticResource HeadingText}" Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Hostname / IP:" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBox x:Name="txtHostname" Grid.Column="1" FontSize="13" Padding="8,6" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Credentials Section -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Text="Credentials" Style="{StaticResource HeadingText}" Margin="0,0,0,4" />
                        <TextBlock Text="Provide administrator credentials for the target computer."
                                   Style="{StaticResource CaptionText}" Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center" Margin="0,0,12,8" />
                            <TextBox x:Name="txtUsername" Grid.Row="0" Grid.Column="1" FontSize="13" Padding="8,6" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center" Margin="0,0,12,8" />
                            <PasswordBox x:Name="txtPassword" Grid.Row="1" Grid.Column="1" FontSize="13" Padding="8,6" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Target User:" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <TextBox x:Name="txtTargetUser" Grid.Row="2" Grid.Column="1" FontSize="13" Padding="8,6" />
                        </Grid>

                        <TextBlock Text="Target User is the account on the destination PC that will receive the migrated data."
                                   Style="{StaticResource CaptionText}" Margin="0,4,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Connection Test Section -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Connection Test" Style="{StaticResource HeadingText}" />
                                <TextBlock x:Name="txtConnectionStatus" Text="Not tested yet."
                                           Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="btnTestConnection" Grid.Column="1" Content="Test Connection"
                                    Style="{StaticResource PrimaryButton}" Padding="16,8" FontSize="13"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
